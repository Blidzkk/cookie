O codigo abaixo funciona apenas no site do Cookie Clicker de navegadores, no caso, para fazelo funcionar coloque o codigo abaixo nas barras de tarefas (na barra de favoritos) e de um clique

javascript:(function(){if(document.getElementById('cc-zerar'))return;var s=document.createElement('style');s.textContent='@keyframes float{0%,100%{transform:translateY(0px);}50%{transform:translateY(-5px);}}@keyframes glow{0%,100%{box-shadow:0 0 10px #f00;}50%{box-shadow:0 0 20px #f00;}}';document.head.appendChild(s);var b=document.createElement('button');b.id='cc-zerar';b.textContent='Zerar Jogo';Object.assign(b.style,{position:'fixed',top:'10px',right:'10px',padding:'12px 20px',background:'linear-gradient(45deg,#800,#a00)',color:'#fff',border:'3px solid #c00',borderRadius:'12px',cursor:'pointer',zIndex:'999999',fontSize:'16px',fontFamily:'serif',fontWeight:'bold',textShadow:'1px 1px 2px #000',boxShadow:'0 4px 8px rgba(0,0,0,0.5)',animation:'float 3s ease-in-out infinite,glow 2s ease-in-out infinite'});b.onclick=function(){if(typeof Game==='undefined'||!Game.cookies){alert('Jogo não pronto.');return;}Game.cookies+=1e1000;Game.cookiesEarned+=1e1000;if(Game.ObjectsById){Game.ObjectsById.forEach(function(o){for(var j=0;j<4500;j++){if(Game.cookies>=o.price)o.buy(1);}});}if(typeof Game.storeBuyAll==='function'){Game.storeBuyAll();}alert('Jogo zerado com 4500+ buildings!');};document.body.appendChild(b);})();

